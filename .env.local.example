# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Project Settings > API no dashboard do supabase.com).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings > API > service_role) — segredo com acesso
# total ao banco, bypassa RLS. Só usado nas rotas app/api/v1/**. NUNCA prefixar
# com NEXT_PUBLIC_ e nunca commitar o valor real.
SUPABASE_SERVICE_ROLE_KEY=
